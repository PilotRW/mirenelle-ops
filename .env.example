DATABASE_URL=postgresql+asyncpg://oa:oa@localhost:5432/mirenelle_ops
ALEMBIC_DATABASE_URL=postgresql+psycopg2://oa:oa@localhost:5432/mirenelle_ops

# Amazon SP-API read-only report downloader.
# Current connector uses LWA access tokens only. Legacy AWS IAM/SigV4 settings
# are intentionally not required for this Reports API flow.
AMAZON_SP_API_REFRESH_TOKEN=
AMAZON_SP_API_LWA_CLIENT_ID=
AMAZON_SP_API_LWA_CLIENT_SECRET=
AMAZON_SP_API_REGION=eu-west-1
AMAZON_SP_API_ENDPOINT=https://sellingpartnerapi-eu.amazon.com

# Optional app authentication.
# Local development normally keeps this disabled and uses AUTH_DEV_USER.
AUTH_ENABLED=false
AUTH_SESSION_SECRET=replace-with-a-long-random-secret
AUTH_ISSUER=
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_REDIRECT_URI=
AUTH_GROUPS_CLAIM=groups
AUTH_DEV_USER=dev@mirenelle.local
AUTH_DEV_ROLES=owner
